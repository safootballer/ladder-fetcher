# ── Database (same PostgreSQL as all other SAFie apps) ────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── NextAuth ──────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""
NEXTAUTH_URL="http://localhost:3002"

# ── Cron job secret (protects the /api/cron endpoint) ─────────────
# Generate any random string e.g: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET="your-random-cron-secret"

# ── Used by the Render cron job to call back into the web service ──
APP_URL="https://safie-leagues.onrender.com"
